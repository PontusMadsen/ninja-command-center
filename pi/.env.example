# === Required ===
GROQ_API_KEY=your_groq_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# === Display ===
DISPLAY_MODE=triptych

# === Timezones (for clock module) ===
LOCAL_TZ=Asia/Tokyo
REMOTE_TZ=Europe/Stockholm
REMOTE_LABEL=Sweden

# === Audio (WM8960 HAT) ===
AUDIO_DEVICE=plughw:wm8960soundcard,0
MIC_DEVICE=plughw:wm8960soundcard,0
MIC_DIRECT=1

# === Web UI ===
WEB_PORT=8888

# === Spotify (optional) ===
SPOTIFY_CLIENT_ID=your_client_id
SPOTIFY_CLIENT_SECRET=your_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:8888/api/spotify/callback

# === Google Cloud TTS (optional — falls back to Piper) ===
# Place google-tts-key.json in pi/ directory

# === Tenor GIF API (optional — has public fallback key) ===
TENOR_API_KEY=your_tenor_key

# === GIF search tag ===
GIF_TAG=cat pixelart

# === Mail IMAP (optional) ===
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your_email
IMAP_PASS=your_app_password

# === Weather (optional) ===
WEATHER_API_KEY=your_openweathermap_key
WEATHER_CITY=Tokyo

# === Google Calendar (optional) ===
GOOGLE_CALENDAR_ID=your_calendar_id
